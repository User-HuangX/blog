# ═══════════════════════════════════════════════════════
# my_blog 环境变量配置示例
# 复制为 .env 并填入真实值：cp .env.example .env
# ⚠️  .env 已被 .gitignore 排除，不会提交到仓库
# ═══════════════════════════════════════════════════════

# ── 数据库连接（必填） ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=my_blog
DB_USER=my_blog
DB_PASSWORD=your-database-password-here

# ── 作者认证（必填） ────────────────────────────────────
BLOG_AUTHOR_PASSWORD=your-author-password-here

# ── 数据库自动迁移（可选，默认 true） ───────────────────
# DB_AUTO_MIGRATE=true

# ── CORS 额外来源（可选，逗号分隔） ─────────────────────
# CORS_EXTRA_ORIGIN_PATTERNS=https://your-domain.com

# ── 服务端口（可选，默认 19080） ────────────────────────
# SERVER_PORT=19080

# ── 会话超时（可选，默认 2h） ───────────────────────────
# SERVER_SESSION_TIMEOUT=2h

# ── 登录速率限制（可选） ─────────────────────────────────
# BLOG_AUTHOR_LOGIN_MAX_ATTEMPTS=5
# BLOG_AUTHOR_LOGIN_WINDOW_SECONDS=60

# ── HTTP 访问日志（可选） ───────────────────────────────
# HTTP_ACCESS_LOG_ENABLED=true
# HTTP_ACCESS_LOG_EXCLUDE=/actuator/**,/error
# HTTP_ACCESS_LOG_MAX_BODY_CHARS=4000
# HTTP_ACCESS_LOG_REQUEST_CACHE_BYTES=524288

# ── SQL 初始化模式（可选，默认 never） ──────────────────
# SPRING_SQL_INIT_MODE=never